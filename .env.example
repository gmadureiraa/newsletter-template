# =============================================================================
# Newsletter Template — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# In production (Vercel), set these in Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Upstash Redis / Vercel KV — required for email storage
# -----------------------------------------------------------------------------
# Get these from either:
#   - Vercel Storage tab → Create "KV" (Upstash Redis) → copy REST credentials
#   - Upstash Console (https://console.upstash.com) → Redis DB → REST API
#
# Without these vars the app enters DEMO mode (form returns "Missing required setup").
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token

# -----------------------------------------------------------------------------
# Optional — Public site URL (used for OG/SEO metadata)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://your-newsletter.vercel.app
